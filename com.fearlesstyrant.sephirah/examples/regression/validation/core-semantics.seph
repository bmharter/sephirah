SephirahDoc coreSemanticsRegression

arithmeticPrecedence;
unaryMinus;
groupedUnaryMinus;
exponentPrecedence;
conditionalTrue;
conditionalFalse;
booleanAnd;
booleanOr;
booleanNot;
groupedCondition;
functionCall;
functionChain;
moduleVariableInFunction;

var score = 10;
var bonus = 4;
var level = 1;
var strength = 18;
var base = 5;

var arithmeticPrecedence = 2 + 3 * 4;
var unaryMinus = score + -1;
var groupedUnaryMinus = -(score + bonus);
var exponentPrecedence = -2 ^ 2;

var conditionalTrue = if score >= 10 then 1 else 0;
var conditionalFalse = if score < 10 then 1 else 0;

var booleanAnd = if score >= 10 and level >= 3 then 1 else 0;
var booleanOr = if score >= 10 or level >= 3 then 1 else 0;
var booleanNot = if not score < 10 then 1 else 0;

var groupedCondition =
    if score >= 10 and [level >= 3 or strength >= 18] then 1 else 0;

var functionCall = addBase(10);
var functionChain = quadruple(3);
var moduleVariableInFunction = addBase(double(7));

def double(x) = x * 2;
def quadruple(x) = double(double(x));
def addBase(x) = x + base;