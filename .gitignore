# Eclipse workspace metadata — never commit the workspace root
.metadata/
.recommenders/
RemoteSystemsTempFiles/

# Java / Xtext / Eclipse build outputs
bin/
target/
build/
*.class
*.xtendbin

# Logs and local temp files
*.log
*.tmp
*.bak
*.swp

# OS/editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/
*.iml

# Keep Eclipse project descriptors unless intentionally removed.
# Xtext/Eclipse plugin projects often rely on .project, .classpath, MANIFEST.MF,
# build.properties, feature.xml, site.xml, and some .settings files.
